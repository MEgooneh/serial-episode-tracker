{
  "manifest_version": 3,
  "name": "Serial Episode Tracker",
  "version": "1.0",
  "description": "Track watched episodes on directory listing pages with checkboxes",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
